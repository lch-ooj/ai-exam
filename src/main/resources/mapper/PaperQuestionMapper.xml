<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ooj.exam.mapper.PaperQuestionMapper">

    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO paper_question (paper_id, question_id, score, create_time, update_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.paperId}, #{item.questionId}, #{item.score}, NOW(), NOW())
        </foreach>
    </insert>
</mapper>